# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Databases & Local Data ---
/data/
*.db
*.sqlite
**/storage/

# --- Environment Secrets ---
.env*
!.env.example

# --- Services (Recursive) ---
**/node_modules/
**/__pycache__/
**/*.py[cod]
**/venv/
**/.venv/

# --- Go (API) ---
services/api-go/api-go
services/api-go/bin/
services/api-go/main

# --- Tauri / Rust (NEW) ---
# This is where Rust compiles the .exe. It can be several GBs.
**/src-tauri/target/
# Tauri's generated icons and schemas
**/src-tauri/gen/
# Rust's lock file is usually kept, but you can ignore it if you want fresh builds every time
# (Standard practice is to keep Cargo.lock, so I'm leaving it out of here)
# --- Tauri / Rust (Additions) ---
# Ignore the setup logs and temporary build artifacts
**/src-tauri/binaries/
**/src-tauri/Cargo.lock.log
# If you use the Tauri sidecar for your Go or Python apps later
**/src-tauri/sidecars/*
!**/src-tauri/sidecars/.gitkeep

# --- Vite / React Frontend (NEW) ---
# Output folder for the web assets
**/dist/
# Vite's internal cache
**/.vite/

# --- Vite / React (Additions) ---
# Ignore the local TypeScript build info
*.tsbuildinfo
# If you ever use Vitest for testing
**/coverage/
# Tailwind/PostCSS cache
.pnpm-debug.log*

# --- Docker ---
docker-compose.override.yml

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*

# --- Misc ---
*.bat